{
  "name": "kuskas-app",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @kuskas-app/db db:push",
    "db:studio": "turbo -F @kuskas-app/db db:studio",
    "db:generate": "turbo -F @kuskas-app/db db:generate",
    "db:migrate": "turbo -F @kuskas-app/db db:migrate",
    "check": "biome check --write .",
    "prepare": "husky"
  },
  "dependencies": {
    "@kuskas-app/env": "*",
    "dotenv": "^17.2.2",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@kuskas-app/config": "*",
    "@types/node": "^22.13.14",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "turbo": "^2.9.16",
    "typescript": "^6"
  },
  "lint-staged": {
    "*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
      "biome check --write ."
    ]
  },
  "packageManager": "npm@10.9.2"
}
